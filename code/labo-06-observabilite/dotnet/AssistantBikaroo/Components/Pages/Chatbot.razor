@page "/"
@rendermode InteractiveServer
@using OllamaSharp.Models
@using OllamaSharp.Models.Chat
@using Microsoft.JSInterop
@inject RagService Rag
@inject McpToolService Mcp
@inject OrchestrationService Orch
@inject SecurityPolicy Policy
@inject TrustedContext Trusted
@inject ObservabilityService Obs
@inject IJSRuntime JS

<PageTitle>Assistant Bikaroo — Labo 6</PageTitle>

<div style="display:flex; gap:1.5rem; max-width:1500px; margin:1rem auto; font-family:sans-serif;">

    @* --- Colonne configuration --- *@
    <aside style="width:300px; flex-shrink:0;">
        <h2>Sécurité</h2>
        <label><input type="radio" name="mode" checked="@Policy.Protected"
                      @onchange="@(() => Policy.Protected = true)" /> Protégé</label><br />
        <label><input type="radio" name="mode" checked="@(!Policy.Protected)"
                      @onchange="@(() => Policy.Protected = false)" /> Vulnérable</label>
        <pre style="background:#f5f5f5; padding:0.5rem; font-size:0.75rem; white-space:pre-wrap;">Membre : @Trusted.AuthenticatedMemberId
Session : @Trusted.SessionId</pre>

        <h2>Observabilité</h2>
        <p style="color:#666; font-size:0.78rem;">Latence simulée : n'affecte que les
            durées, jamais le résultat métier.</p>
        <label>Latence LLM : @Obs.Latency[SpanCategory.Llm] ms</label>
        <input type="range" min="0" max="2000" step="100" style="width:100%"
               value="@Obs.Latency[SpanCategory.Llm]"
               @onchange="@(e => Obs.Latency[SpanCategory.Llm] = int.Parse(e.Value?.ToString() ?? "0"))" />
        <label>Latence RAG : @Obs.Latency[SpanCategory.Rag] ms</label>
        <input type="range" min="0" max="2000" step="100" style="width:100%"
               value="@Obs.Latency[SpanCategory.Rag]"
               @onchange="@(e => Obs.Latency[SpanCategory.Rag] = int.Parse(e.Value?.ToString() ?? "0"))" />
        <label>Latence MCP : @Obs.Latency[SpanCategory.Mcp] ms</label>
        <input type="range" min="0" max="2000" step="100" style="width:100%"
               value="@Obs.Latency[SpanCategory.Mcp]"
               @onchange="@(e => Obs.Latency[SpanCategory.Mcp] = int.Parse(e.Value?.ToString() ?? "0"))" />

        <h3>Configuration</h3>
        <label><input type="checkbox" @bind="useRag" /> Avec RAG (hors processus)</label>
        <label>Température : @temperature.ToString("0.0")</label>
        <input type="range" min="0" max="1" step="0.1" @bind="temperature" style="width:100%;" />
        <label>Max tokens : @maxTokens</label>
        <input type="range" min="64" max="2048" step="64" @bind="maxTokens" style="width:100%;" />
        <label>top-k : @topK</label>
        <input type="range" min="1" max="6" step="1" @bind="topK" style="width:100%;" />

        @if (mcpTools is not null)
        {
            <p style="color:#137333; font-size:0.8rem;">MCP connecté</p>
        }
        else
        {
            <p style="color:#b06000; font-size:0.8rem;">MCP injoignable</p>
        }
        <button @onclick="ClearConversation">Effacer la conversation</button>
    </aside>

    @* --- Colonne conversation --- *@
    <main style="flex:1; min-width:340px;">
        <h1>🔭 Assistant Bikaroo</h1>
        <p><em>Labo 6 — Observabilité · mode @(Policy.Protected ? "Protégé" : "Vulnérable")
            · @Mcp.Model + @RagService.EmbeddingModel · @Rag.IndexSize chunks</em></p>

        @if (process is not null && process.Active)
        {
            <p style="background:#e8f0fe; padding:0.5rem; border-radius:6px;">
                <strong>Processus — Étape @process.Step/5 :
                @OrchestrationService.StepLabels[process.Step]</strong></p>
        }

        <div style="border:1px solid #ccc; padding:1rem; min-height:160px; margin-bottom:1rem;">
            @if (messages.Count == 0)
            {
                <p style="color:#888;">La conversation est vide.</p>
            }
            @foreach (var m in messages)
            {
                <p><strong>@(m.Role == "user" ? "Vous" : "Assistant") :</strong> @m.Content</p>
            }
        </div>

        @if (errorMessage is not null)
        {
            <p style="color:#b00020;">@errorMessage</p>
        }

        <div style="display:flex; gap:0.5rem;">
            <input @bind="userInput" @bind:event="oninput" @onkeydown="OnKeyDown"
                   placeholder="Posez votre question…" style="flex-grow:1;" disabled="@isGenerating" />
            <button @onclick="SendAsync" disabled="@(isGenerating || string.IsNullOrWhiteSpace(userInput))">
                @(isGenerating ? "…" : "Envoyer")
            </button>
        </div>

        @if (process is not null && process.Active && process.NeedConfirmation)
        {
            <div style="display:flex; gap:0.5rem; margin-top:0.75rem;">
                <button @onclick="ConfirmAsync" disabled="@isGenerating"
                        style="flex:1; background:#137333; color:white; padding:0.5rem;">✅ Confirmer</button>
                <button @onclick="CancelProcess" disabled="@isGenerating"
                        style="flex:1; padding:0.5rem;">✖ Annuler</button>
            </div>
        }
    </main>

    @* --- Colonne observabilité --- *@
    <section style="width:430px; flex-shrink:0;">
        <h2>🔭 Observabilité</h2>
        @if (!Obs.Traces.Any())
        {
            <p style="color:#888; font-size:0.85rem;">Aucune trace : posez une question.</p>
        }
        else
        {
            <label>Historique des traces</label>
            <select style="width:100%;" @onchange="OnTraceSelected">
                @foreach (var t in Obs.Traces.Reverse())
                {
                    <option value="@t.TraceId" selected="@(t.TraceId == selectedTraceId)">
                        @t.TraceId — @(string.IsNullOrEmpty(t.FinalOutcome) ? t.Status : t.FinalOutcome) — @t.DurationMs ms
                    </option>
                }
            </select>

            <h3>Vue synthétique</h3>
            <pre style="background:#f5f5f5; padding:0.5rem; font-size:0.75rem; white-space:pre-wrap;">Trace       : @SelectedTrace!.TraceId
Résultat    : @((string.IsNullOrEmpty(SelectedTrace!.FinalOutcome) ? "—" : SelectedTrace!.FinalOutcome).ToUpperInvariant())  (statut : @SelectedTrace!.Status)
Durée totale: @SelectedMetrics!.total_duration_ms ms
Spans       : @SelectedTrace!.Spans.Count
LLM         : @SelectedMetrics!.llm_calls appels / @SelectedMetrics!.llm_duration_ms ms
RAG         : @SelectedMetrics!.rag_searches recherche(s) / @SelectedMetrics!.rag_duration_ms ms
MCP         : @SelectedMetrics!.mcp_calls appels / @SelectedMetrics!.mcp_duration_ms ms
Sécurité    : @SelectedMetrics!.security_event_count événement(s)
Transitions : @SelectedMetrics!.workflow_transition_count
Erreurs     : @SelectedMetrics!.error_count</pre>

            <details open>
                <summary>Chronologie</summary>
                <ul style="font-size:0.78rem;">
                    @foreach (var s in SelectedTrace!.Spans)
                    {
                        <li><code>@s.OffsetMs ms</code>
                            @(s.Status == TraceStatus.Failed ? "❌" : "✅")
                            <strong>@s.Name</strong> <em>(@s.Category)</em> — @s.DurationMs ms</li>
                    }
                </ul>
            </details>

            <details>
                <summary>Détails des spans</summary>
                @foreach (var s in SelectedTrace!.Spans)
                {
                    <p style="font-size:0.78rem; margin:0.4rem 0;">
                        <strong>@s.Name</strong> · <code>@s.Category</code> · @s.DurationMs ms ·
                        statut <code>@s.Status</code><br />
                        @foreach (var a in s.Attributes)
                        {
                            <span style="color:#555;">@a.Key=@FormatValue(a.Value) </span>
                        }
                        @if (s.Error.Length > 0)
                        {
                            <span style="color:#b00020;">@s.Error</span>
                        }
                    </p>
                }
            </details>

            <details>
                <summary>Transitions du workflow</summary>
                <ul style="font-size:0.78rem;">
                    @foreach (var t in SelectedTrace!.WorkflowTransitions)
                    {
                        <li><code>@t.Timestamp</code> <strong>@t.StepBefore → @t.StepAfter</strong> — @t.Reason</li>
                    }
                </ul>
            </details>

            <details>
                <summary>Événements de sécurité (@SelectedTrace!.SecurityEvents.Count)</summary>
                <ul style="font-size:0.78rem;">
                    @foreach (var e in SelectedTrace!.SecurityEvents)
                    {
                        <li><code>@e.Timestamp</code> <strong>[@e.Attributes.GetValueOrDefault("action")]</strong>
                            <code>@e.EventType</code> — @e.Details</li>
                    }
                </ul>
            </details>

            <details>
                <summary>Événements d'application (@SelectedTrace!.Events.Count)</summary>
                <ul style="font-size:0.78rem;">
                    @foreach (var e in SelectedTrace!.Events)
                    {
                        <li><code>@e.Timestamp</code> <code>@e.EventType</code> (@e.Severity) — @e.Details</li>
                    }
                </ul>
            </details>

            <button @onclick="@(() => ExportAsync(SelectedTrace!))" style="margin-top:0.5rem;">
                ⬇️ Exporter la trace JSON
            </button>
        }
    </section>
</div>

@code {
    private bool useRag = true;
    private double temperature = 0.7;
    private int maxTokens = 512;
    private int topK = 4;

    private string systemPrompt =
        "Tu es l'Assistant Bikaroo, l'assistant virtuel de Bikaroo, une société de vélos "
        + "partagés à Bruxelles. Tu réponds en français, brièvement. Tu disposes d'un contexte "
        + "documentaire et de tools de lecture. Appuie-toi dessus et n'invente pas.";

    private string userInput = string.Empty;
    private bool isGenerating;
    private string? errorMessage;
    private string? selectedTraceId;

    private readonly List<ChatMessage> messages = new();
    private RevisionProcess? process;
    private List<string>? mcpTools;

    private record ChatMessage(string Role, string Content);

    private RunContext Ctx => new(Policy, Trusted, Obs);

    // Trace affichée dans le panneau (sélection ou la plus récente).
    private TraceContext? SelectedTrace =>
        Obs.Traces.FirstOrDefault(t => t.TraceId == selectedTraceId) ?? Obs.Traces.LastOrDefault();
    private TraceMetrics? SelectedMetrics => SelectedTrace?.Metrics();

    private static string FormatValue(object? value) => value switch
    {
        null => "—",
        System.Collections.IEnumerable e and not string =>
            string.Join("|", e.Cast<object?>().Take(4).Select(x => x?.ToString())),
        _ => value.ToString() ?? "",
    };

    protected override async Task OnInitializedAsync()
    {
        try { mcpTools = await Mcp.ListToolNamesAsync(); }
        catch { mcpTools = null; }
    }

    private void OnTraceSelected(ChangeEventArgs e) => selectedTraceId = e.Value?.ToString();

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") { await SendAsync(); }
    }

    private static string TraceStatusFor(string outcome) => outcome switch
    {
        TraceOutcome.Created or TraceOutcome.Answered => TraceStatus.Completed,
        TraceOutcome.Refused or TraceOutcome.NotEligible => TraceStatus.Refused,
        TraceOutcome.Cancelled or TraceOutcome.Aborted => TraceStatus.Cancelled,
        TraceOutcome.Failed => TraceStatus.Failed,
        _ => TraceStatus.Completed,
    };

    private async Task SendAsync()
    {
        if (string.IsNullOrWhiteSpace(userInput) || isGenerating) { return; }

        errorMessage = null;
        messages.Add(new ChatMessage("user", userInput));
        var question = userInput;
        userInput = string.Empty;
        isGenerating = true;

        var trace = Obs.StartTrace(question);      // une trace par interaction
        selectedTraceId = trace.TraceId;
        var outcome = TraceOutcome.Answered;
        try
        {
            string answer;
            if (process is not null && process.Active)
            {
                answer = await Orch.HandleMessageAsync(process, question, Ctx);
                outcome = process.Outcome ?? TraceOutcome.Answered;
            }
            else if (mcpTools is not null && await Orch.DetectRevisionIntentAsync(question, Ctx))
            {
                process = OrchestrationService.NewProcess(Trusted);
                process.TripId = OrchestrationService.FindTripId(question);
                answer = await Orch.AdvanceAfterStartAsync(process, question, Ctx);
                outcome = process.Outcome ?? TraceOutcome.Answered;
            }
            else
            {
                Policy.ScanForInjection(question, "user_message");
                var context = string.Empty;
                if (useRag)
                {
                    using var ragSpan = Obs.StartSpan("rag_search", SpanCategory.Rag,
                        ("query", question.Length > 80 ? question[..80] : question), ("top_k", topK));
                    var chunks = await Rag.SearchAsync(question, topK);
                    var rawContext = RagService.BuildContext(chunks);
                    ragSpan.Set("result_count", chunks.Count)
                           .Set("documents", chunks.Select(c => c.Document).ToList())
                           .Set("scores", chunks.Select(c => Math.Round(c.Score, 3)).ToList())
                           .Set("context_chars", rawContext.Length);
                    if (chunks.Count == 0)
                    {
                        Obs.RecordEvent(AppEventType.RagNoResult, "rag", "warning",
                            "Aucun extrait documentaire retrouvé.");
                    }
                    Policy.ScanForInjection(rawContext, "rag_document");
                    context = Policy.WrapUntrusted(rawContext, SecurityPolicy.UntrustedDocumentsTag);
                }

                var prompt = systemPrompt;
                if (Policy.Protected) { prompt += "\n" + SecurityPolicy.UntrustedPromptRule(); }
                var chatMessages = new List<Message>
                {
                    new() { Role = ChatRole.System, Content = prompt },
                };
                if (context.Length > 0)
                {
                    chatMessages.Add(new Message { Role = ChatRole.System,
                        Content = "Contexte documentaire :\n\n" + context });
                }
                foreach (var m in messages)
                {
                    chatMessages.Add(new Message
                    {
                        Role = m.Role == "user" ? ChatRole.User : ChatRole.Assistant,
                        Content = m.Content,
                    });
                }

                using var llmSpan = Obs.StartSpan("llm_formulation", SpanCategory.Llm,
                    ("model", Mcp.Model), ("call_type", "free_chat"),
                    ("input_chars", chatMessages.Sum(x => x.Content?.Length ?? 0)));
                var result = await Mcp.AnswerAsync(chatMessages,
                    new RequestOptions { Temperature = (float)temperature, NumPredict = maxTokens });
                answer = result.Text;
                llmSpan.Set("output_chars", answer.Length)
                       .Set("estimated_output_tokens", TraceMetrics.EstimateTokens(answer))
                       .Set("mcp_available", result.McpAvailable)
                       .Set("tool_calls", result.ToolCalls.Count);
                if (!result.McpAvailable)
                {
                    Obs.RecordEvent(AppEventType.McpUnavailable, "mcp", "warning",
                        "Serveur MCP injoignable : réponse sans tools.");
                }
            }

            using (Obs.StartSpan("final_response", SpanCategory.Application,
                ("output_chars", answer.Length), ("outcome", outcome))) { }
            messages.Add(new ChatMessage("assistant", answer));
        }
        catch (Exception ex)
        {
            outcome = TraceOutcome.Failed;
            Obs.RecordError("application_error", "application", ex.Message);
            errorMessage = $"Une erreur est survenue. Détail : {ex.Message}";
        }
        finally
        {
            Obs.FinishTrace(TraceStatusFor(outcome), outcome);
            isGenerating = false;
        }
    }

    private async Task ConfirmAsync()
    {
        if (process is null || isGenerating) { return; }
        isGenerating = true;
        var trace = Obs.StartTrace("Clic sur Confirmer");
        selectedTraceId = trace.TraceId;
        var outcome = TraceOutcome.Refused;
        try
        {
            var message = await Orch.ConfirmAsync(process, Ctx);
            messages.Add(new ChatMessage("assistant", message));
            outcome = process.Outcome ?? TraceOutcome.Refused;
        }
        catch (Exception ex)
        {
            outcome = TraceOutcome.Failed;
            Obs.RecordError("application_error", "application", ex.Message);
            errorMessage = $"Impossible de créer la demande. Détail : {ex.Message}";
        }
        finally
        {
            Obs.FinishTrace(TraceStatusFor(outcome), outcome);
            isGenerating = false;
        }
    }

    private void CancelProcess()
    {
        if (process is null) { return; }
        var trace = Obs.StartTrace("Clic sur Annuler");
        selectedTraceId = trace.TraceId;
        messages.Add(new ChatMessage("assistant", Orch.Cancel(process, Ctx)));
        Obs.FinishTrace(TraceStatus.Cancelled, TraceOutcome.Cancelled);
    }

    private async Task ExportAsync(TraceContext trace)
    {
        var json = Obs.ExportJson(trace);
        // Téléchargement côté navigateur : pas de persistance serveur.
        await JS.InvokeVoidAsync("eval", $$"""
            (function(){
              const blob = new Blob([{{System.Text.Json.JsonSerializer.Serialize(json)}}],
                                    {type:'application/json'});
              const a = document.createElement('a');
              a.href = URL.createObjectURL(blob);
              a.download = '{{trace.TraceId}}.json';
              a.click(); URL.revokeObjectURL(a.href);
            })();
            """);
    }

    private void ClearConversation()
    {
        messages.Clear();
        process = null;
        errorMessage = null;
    }
}
