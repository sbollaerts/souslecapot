@page "/"
@rendermode InteractiveServer
@using System.Diagnostics
@using System.Text
@using OllamaSharp
@using OllamaSharp.Models
@using OllamaSharp.Models.Chat
@inject OllamaApiClient Ollama

@* Squelette de départ. La plomberie Blazor et l'injection du client Ollama sont
   déjà en place. À vous d'implémenter le cœur du labo (voir les « TODO »). *@

<PageTitle>Assistant Bikaroo — Labo 1</PageTitle>

<div style="display:flex; gap:2rem; max-width:1100px; margin:1rem auto; font-family:sans-serif;">

    @* --- Colonne configuration : prompt système et paramètres de génération --- *@
    <aside style="width:320px; flex-shrink:0;">
        <h2>Configuration</h2>

        <label><strong>Prompt système</strong></label>
        <textarea @bind="systemPrompt" rows="8" style="width:100%;"></textarea>

        <h3>Paramètres de génération</h3>

        <label>Température : @temperature.ToString("0.0")</label>
        <input type="range" min="0" max="1" step="0.1" @bind="temperature" style="width:100%;" />

        <label>Nombre maximum de tokens en sortie : @maxTokens</label>
        <input type="range" min="64" max="2048" step="64" @bind="maxTokens" style="width:100%;" />

        <button @onclick="ClearConversation" style="margin-top:1rem;">Effacer la conversation</button>
    </aside>

    @* --- Colonne conversation --- *@
    <main style="flex-grow:1;">
        <h1>🚲 Assistant Bikaroo</h1>
        <p><em>Labo 1 — Chatbot local (Ollama · modèle « @Model »)</em></p>

        <div style="border:1px solid #ccc; padding:1rem; min-height:200px; margin-bottom:1rem;">
            @if (messages.Count == 0)
            {
                <p style="color:#888;">La conversation est vide. Posez une question ci-dessous.</p>
            }
            @foreach (var message in messages)
            {
                <p><strong>@(message.Role == "user" ? "Vous" : "Assistant") :</strong> @message.Content</p>
            }
        </div>

        @if (errorMessage is not null)
        {
            <p style="color:#b00020;">@errorMessage</p>
        }

        <div style="display:flex; gap:0.5rem;">
            <input @bind="userInput" @bind:event="oninput" @onkeydown="OnKeyDown"
                   placeholder="Posez votre question…" style="flex-grow:1;" disabled="@isGenerating" />
            <button @onclick="SendAsync" disabled="@(isGenerating || string.IsNullOrWhiteSpace(userInput))">
                @(isGenerating ? "…" : "Envoyer")
            </button>
        </div>

        @* TODO (étape 4) — Zone d'informations techniques.
             Si lastCallInfo n'est pas null, affichez-le (par ex. dans un <details>) :
             modèle, température, max tokens, durée de génération. *@
    </main>
</div>

@code {
    // Modèle fixé pour ce labo (bonnes performances en français).
    private const string Model = "mistral";

    // TODO (étape 1) — Prompt système par défaut.
    // Rédigez un prompt qui positionne l'assistant comme « Assistant Bikaroo »
    // (société de vélos partagés à Bruxelles), répondant en français.
    // N'y mettez AUCUNE connaissance des documents internes : ce sera l'objet du labo 2 (RAG).
    private string systemPrompt = "";

    private double temperature = 0.7;
    private int maxTokens = 512;

    private string userInput = string.Empty;
    private bool isGenerating;
    private string? errorMessage;

    // Historique de la conversation (utilisateur / assistant), dans l'ordre chronologique.
    private readonly List<ChatMessage> messages = new();
    private Dictionary<string, string>? lastCallInfo;

    private record ChatMessage(string Role, string Content);

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SendAsync();
        }
    }

    private async Task SendAsync()
    {
        if (string.IsNullOrWhiteSpace(userInput) || isGenerating)
        {
            return;
        }

        errorMessage = null;
        messages.Add(new ChatMessage("user", userInput));
        userInput = string.Empty;
        isGenerating = true;

        try
        {
            // TODO (étape 3) — Appel au modèle.
            //   a) Construisez la liste des messages à envoyer : un Message avec
            //      Role = ChatRole.System et Content = systemPrompt, puis un Message
            //      par élément de `messages` (ChatRole.User / ChatRole.Assistant).
            //   b) Créez un ChatRequest (Model, Stream = false, Messages, et un
            //      RequestOptions avec Temperature et NumPredict = maxTokens).
            //   c) Mesurez la durée (Stopwatch), appelez Ollama.ChatAsync(request)
            //      et concaténez chunk.Message.Content.
            //   d) Ajoutez la réponse à `messages` et renseignez `lastCallInfo`
            //      (modèle, température, max tokens, durée).
            // Le try/catch entoure déjà l'appel : en cas d'échec (Ollama non lancé,
            // modèle absent), un message clair est affiché à l'utilisateur.
            await Task.CompletedTask; // à remplacer par l'appel réel
        }
        catch (Exception ex)
        {
            errorMessage =
                $"Impossible de contacter Ollama. Vérifiez qu'Ollama est bien lancé "
                + $"et que le modèle « {Model} » est téléchargé (commande : ollama pull {Model}). "
                + $"Détail technique : {ex.Message}";
        }
        finally
        {
            isGenerating = false;
        }
    }

    private void ClearConversation()
    {
        // Vide la conversation mais conserve le prompt système et les paramètres.
        messages.Clear();
        lastCallInfo = null;
        errorMessage = null;
    }
}
