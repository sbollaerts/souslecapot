@page "/"
@rendermode InteractiveServer
@using System.Diagnostics
@using System.Text
@using OllamaSharp
@using OllamaSharp.Models
@using OllamaSharp.Models.Chat
@inject OllamaApiClient Ollama
@inject RagService Rag

<PageTitle>Assistant Bikaroo — Labo 2</PageTitle>

<div style="display:flex; gap:2rem; max-width:1100px; margin:1rem auto; font-family:sans-serif;">

    @* --- Colonne configuration --- *@
    <aside style="width:340px; flex-shrink:0;">
        <h2>Configuration</h2>

        <label>
            <input type="checkbox" @bind="useRag" />
            <strong>Avec RAG</strong>
        </label>
        <p style="color:#666; font-size:0.85rem; margin-top:0.25rem;">
            Activé : la réponse s'appuie sur le corpus Bikaroo.
            Désactivé : le modèle répond seul, comme au labo 1.
        </p>

        <label><strong>Prompt système</strong></label>
        <textarea @bind="systemPrompt" rows="9" style="width:100%;"></textarea>

        <h3>Paramètres de génération</h3>

        <label>Température : @temperature.ToString("0.0")</label>
        <input type="range" min="0" max="1" step="0.1" @bind="temperature" style="width:100%;" />

        <label>Nombre maximum de tokens en sortie : @maxTokens</label>
        <input type="range" min="64" max="2048" step="64" @bind="maxTokens" style="width:100%;" />

        <label>Nombre de chunks récupérés (top-k) : @topK</label>
        <input type="range" min="1" max="6" step="1" @bind="topK" style="width:100%;" />

        <button @onclick="ClearConversation" style="margin-top:1rem;">Effacer la conversation</button>
    </aside>

    @* --- Colonne conversation --- *@
    <main style="flex-grow:1;">
        <h1>🚲 Assistant Bikaroo</h1>
        <p><em>Labo 2 — RAG documentaire (Ollama · @Model + @RagService.EmbeddingModel ·
            @Rag.IndexSize chunks indexés)</em></p>

        <div style="border:1px solid #ccc; padding:1rem; min-height:200px; margin-bottom:1rem;">
            @if (messages.Count == 0)
            {
                <p style="color:#888;">La conversation est vide. Posez une question ci-dessous.</p>
            }
            @foreach (var message in messages)
            {
                <p><strong>@(message.Role == "user" ? "Vous" : "Assistant") :</strong> @message.Content</p>
            }
        </div>

        @if (errorMessage is not null)
        {
            <p style="color:#b00020;">@errorMessage</p>
        }

        <div style="display:flex; gap:0.5rem;">
            <input @bind="userInput" @bind:event="oninput" @onkeydown="OnKeyDown"
                   placeholder="Posez votre question…" style="flex-grow:1;" disabled="@isGenerating" />
            <button @onclick="SendAsync" disabled="@(isGenerating || string.IsNullOrWhiteSpace(userInput))">
                @(isGenerating ? "…" : "Envoyer")
            </button>
        </div>

        @* --- Informations techniques sur le dernier appel --- *@
        @if (lastCallInfo is not null)
        {
            <details open style="margin-top:1rem;">
                <summary>Informations techniques sur le dernier appel</summary>
                <ul>
                    @foreach (var item in lastCallInfo)
                    {
                        <li><strong>@item.Key :</strong> @item.Value</li>
                    }
                </ul>

                @* Sources / chunks retrouvés (uniquement en mode RAG). *@
                @if (lastSources is not null && lastSources.Count > 0)
                {
                    <p style="margin-bottom:0.25rem;"><strong>Sources retrouvées :</strong></p>
                    <ul>
                        @foreach (var source in lastSources)
                        {
                            <li>
                                <code>@source.Score.ToString("0.000")</code> —
                                <strong>@source.Document</strong> (@source.Heading)
                                <blockquote style="color:#555; margin:0.25rem 0 0.5rem;">@Excerpt(source.Content)</blockquote>
                            </li>
                        }
                    </ul>
                }
            </details>
        }
    </main>
</div>

@code {
    // Modèle de génération (identique au labo 1).
    private const string Model = "mistral";

    // Prompt système par défaut : invite le modèle à s'appuyer sur le contexte
    // documentaire et à reconnaître l'absence d'information plutôt que d'inventer.
    private string systemPrompt =
        "Tu es l'Assistant Bikaroo, l'assistant virtuel de Bikaroo, une société "
        + "de vélos partagés à Bruxelles. Tu réponds toujours en français, de "
        + "manière claire, polie et concise.\n"
        + "Lorsqu'un contexte documentaire t'est fourni, appuie-toi uniquement sur "
        + "ce contexte pour répondre et cite les documents sources utilisés. Si "
        + "l'information demandée ne figure pas dans le contexte, dis-le clairement "
        + "au lieu d'inventer une réponse.";

    private bool useRag = true;
    private double temperature = 0.7;
    private int maxTokens = 512;
    private int topK = 4;

    private string userInput = string.Empty;
    private bool isGenerating;
    private string? errorMessage;

    private readonly List<ChatMessage> messages = new();
    private Dictionary<string, string>? lastCallInfo;
    private List<Chunk>? lastSources;

    private record ChatMessage(string Role, string Content);

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SendAsync();
        }
    }

    private async Task SendAsync()
    {
        if (string.IsNullOrWhiteSpace(userInput) || isGenerating)
        {
            return;
        }

        errorMessage = null;
        messages.Add(new ChatMessage("user", userInput));
        var question = userInput;
        userInput = string.Empty;
        isGenerating = true;

        try
        {
            // En mode RAG : rechercher les chunks pertinents et construire le contexte.
            var context = string.Empty;
            lastSources = null;
            if (useRag)
            {
                lastSources = await Rag.SearchAsync(question, topK);
                context = RagService.BuildContext(lastSources);
            }

            // Prompt système, puis (en RAG) le contexte documentaire, puis l'historique.
            var chatMessages = new List<Message>
            {
                new() { Role = ChatRole.System, Content = systemPrompt },
            };
            if (context.Length > 0)
            {
                chatMessages.Add(new Message
                {
                    Role = ChatRole.System,
                    Content = "Contexte documentaire (extraits de la base de "
                        + "connaissances Bikaroo) :\n\n" + context,
                });
            }
            foreach (var message in messages)
            {
                chatMessages.Add(new Message
                {
                    Role = message.Role == "user" ? ChatRole.User : ChatRole.Assistant,
                    Content = message.Content,
                });
            }

            var request = new ChatRequest
            {
                Model = Model,
                Stream = false,
                Messages = chatMessages,
                Options = new RequestOptions
                {
                    Temperature = (float)temperature,
                    NumPredict = maxTokens,
                },
            };

            var stopwatch = Stopwatch.StartNew();
            var answer = new StringBuilder();
            await foreach (var chunk in Ollama.ChatAsync(request))
            {
                answer.Append(chunk?.Message?.Content ?? string.Empty);
            }
            stopwatch.Stop();

            messages.Add(new ChatMessage("assistant", answer.ToString()));
            lastCallInfo = new Dictionary<string, string>
            {
                ["Mode"] = useRag ? "Avec RAG" : "Sans RAG",
                ["Modèle"] = Model,
                ["Modèle d'embeddings"] = useRag ? RagService.EmbeddingModel : "—",
                ["Température"] = temperature.ToString("0.0"),
                ["Max tokens"] = maxTokens.ToString(),
                ["Chunks récupérés (top-k)"] = useRag ? topK.ToString() : "—",
                ["Durée de génération"] = $"{stopwatch.Elapsed.TotalSeconds:0.00} s",
            };
        }
        catch (Exception ex)
        {
            errorMessage =
                $"Impossible de contacter Ollama. Vérifiez qu'Ollama est bien lancé "
                + $"et que les modèles « {Model} » et « {RagService.EmbeddingModel} » "
                + $"sont téléchargés. Détail technique : {ex.Message}";
        }
        finally
        {
            isGenerating = false;
        }
    }

    private void ClearConversation()
    {
        // Vide la conversation mais conserve le prompt système et les paramètres.
        messages.Clear();
        lastCallInfo = null;
        lastSources = null;
        errorMessage = null;
    }

    private static string Excerpt(string content)
    {
        var text = content.Replace("\n", " ");
        return text.Length > 200 ? text[..200] + "…" : text;
    }
}
